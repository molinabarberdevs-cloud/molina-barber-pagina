---
import Base from '../layouts/Base.astro';

export const prerender = false;

// El middleware nos dirá si el usuario está logueado.
// `Astro.locals.isLoggedIn` será `true` si la cookie de sesión es válida.
const { isLoggedIn, isAdmin } = Astro.locals; 

// Leemos el mensaje de error de la URL si existe
const { searchParams } = Astro.url;
const errorMessage = searchParams.get('error');
const successMessage = searchParams.get('message');
---

<Base title="Admin | Molina's Club">
  <main class="wrap" style="padding-top: 4rem; padding-bottom: 4rem;">
    {
      !isLoggedIn && (
        <section id="login-view" class="login-box glass-panel">
          <div class="logo">
            <span class="logo-icon">✂️</span>
            <div>
              <span class="logo-name">Molina's</span>
              <span class="logo-sub">Admin Panel</span>
            </div>
          </div>
          <h1 class="display">Acceso para Barberos</h1>
          <p class="section-body">
            Inicia sesión para administrar clientes y campañas.
          </p>
          <form id="login-form" method="POST" action="/api/auth/login">
            <div class="input-group vertical">
              <input type="email" id="email" name="email" class="input" placeholder="Correo electrónico" required />
              <input type="password" id="password" name="password" class="input" placeholder="Contraseña" required />
            </div>
            <div id="message-container" style="margin-top: 1rem;">
              {errorMessage && <p class="error-msg">{errorMessage}</p>}
              {successMessage && <p class="success-msg">{successMessage}</p>}
            </div>
            <button type="submit" id="login-button" class="btn btn-gold btn-full" style="margin-top: 1.5rem;">
              Ingresar al Panel
            </button>
          </form>
          <a href="/registro-barbero" class="subtle-link">¿No tienes cuenta? Regístrate aquí</a>
        </section>
      )
    }
    {
      isLoggedIn && !isAdmin && (
        <section id="pending-view" class="login-box glass-panel">
          <h1 class="display">Cuenta Pendiente</h1>
          <p class="section-body">
            Tu cuenta ha sido creada y has iniciado sesión, pero aún no tienes
            permisos de administrador. Por favor, contacta al dueño del local para
            que active tu acceso.
          </p>
          <a href="/api/auth/signout" class="btn btn-ghost btn-full">Cerrar Sesión</a>
        </section>
      )
    }
    {
      isAdmin && (
        <div id="admin-view" class="admin-panel">
          <header class="admin-header">
            <div>
              <h1 class="display">Panel de Administración</h1>
              <p class="section-body">
                Bienvenido. Desde aquí puedes gestionar los clientes del club.
              </p>
            </div>
            <a href="/api/auth/signout" class="btn btn-ghost">
              Cerrar Sesión
            </a>
          </header>

           {/* Sección de Búsqueda y Suma de Cortes */}
          <section id="search-section" class="admin-card glass-panel">
            <h2 class="card-title">Buscar y Sumar Corte</h2>
            <div class="input-group">
              <input
                type="text"
                id="input-rut"
                class="input"
                placeholder="RUT del cliente"
              />
              <button id="btn-search" class="btn btn-gold">
                <span id="btn-search-text">Buscar</span>
                <span id="btn-search-loading" class="loading-spinner" hidden></span>
              </button>
            </div>
            <p id="search-error" class="error-msg" style="display: none;"></p>

            <div id="result-section" style="display: none; margin-top: 2rem;">
              <h3 id="client-name" class="client-name"></h3>
              <p id="client-rut" class="client-rut mono"></p>
              <div class="cortes-display">
                <p>Cortes actuales:</p>
                <p id="client-cortes" class="cortes-count"></p>
              </div>
              <button id="btn-add" class="btn btn-ghost btn-full">
                <span id="btn-add-text">+1 Sumar Corte Ahora</span>
                <span id="btn-add-loading" class="loading-spinner" hidden></span>
              </button>
              <p id="add-success" class="success-msg" style="display: none;">
                ¡Corte sumado con éxito!
              </p>
            </div>
          </section>

          {/* Directorio y Gestión de BD */}
          <section id="directory-section" class="admin-card glass-panel" style="margin-top: 2rem;">
            <h2 class="card-title">Directorio de Clientes</h2>
            <p class="section-body" style="margin-bottom: 1.5rem;">Gestiona y limpia la base de datos.</p>
            
            <button id="btn-load-dir" class="btn btn-ghost btn-full" style="margin-bottom: 1.5rem;">
              <span id="btn-load-text">📂 Cargar todos los registros</span>
              <span id="btn-load-loading" class="loading-spinner" hidden></span>
            </button>

            <div id="dir-list" style="display: flex; flex-direction: column; gap: 1rem;">
              {/* Items generados dinámicamente */}
            </div>
          </section>

          {/* Campaña de Notificaciones (Spam del Local) */}
          <section id="marketing-section" class="admin-card glass-panel" style="margin-top: 2rem;">
            <h2 class="card-title">📢 Campaña de Notificaciones (Spam del Local)</h2>
            <p class="section-body" style="margin-bottom: 1.5rem;">Envía un mensaje push instantáneo a todos los socios del club.</p>
            
            <div class="field" style="margin-bottom: 1rem;">
              <label class="label" for="marketing-title">Título de la Notificación</label>
              <input
                id="marketing-title"
                type="text"
                class="input"
                placeholder="Ej: ¡Promoción de mitad de semana! 💈"
              />
            </div>

            <div class="field" style="margin-bottom: 1.5rem;">
              <label class="label" for="marketing-body">Cuerpo del Mensaje</label>
              <textarea
                id="marketing-body"
                class="input"
                placeholder="Ej: Solo por hoy, 15% de descuento en barbas completas. ¡Reserva tu hora!"
                style="min-height: 80px; resize: vertical; padding: 0.8rem;"
              ></textarea>
            </div>

            <button id="btn-send-marketing" class="btn btn-gold btn-full">
              <span id="btn-marketing-text">🚀 Enviar Notificación a Todos</span>
              <span id="btn-marketing-loading" class="loading-spinner" hidden></span>
            </button>

            <p id="marketing-success" class="success-msg" style="text-align: center; margin-top: 1rem; display: none;">
              ¡Campaña enviada exitosamente a todos los suscriptores!
            </p>
          </section>

          {/* Ciclos de Notificaciones (Automático) */}
          <section id="cycle-section" class="admin-card glass-panel" style="margin-top: 2rem;">
            <h2 class="card-title">⚙️ Ciclos Automáticos</h2>
            <p class="section-body" style="margin-bottom: 1.5rem;">Configura un mensaje que se enviará repetidamente según la frecuencia elegida.</p>
            
            <div class="field" style="margin-bottom: 1rem;">
              <label class="label" for="cycle-title">Título del Mensaje</label>
              <input
                id="cycle-title"
                type="text"
                class="input"
                placeholder="Ej: Recuerda tu corte 💈"
              />
            </div>

            <div class="field" style="margin-bottom: 1rem;">
              <label class="label" for="cycle-body">Cuerpo del Mensaje</label>
              <textarea
                id="cycle-body"
                class="input"
                placeholder="Ej: Ya es hora de arreglar esa barba. ¡Te esperamos!"
                style="min-height: 80px; resize: vertical; padding: 0.8rem;"
              ></textarea>
            </div>

            <div class="field" style="margin-bottom: 1.5rem;">
              <label class="label" for="cycle-freq">Frecuencia</label>
              <select id="cycle-freq" class="input" style="padding: 0.8rem; background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 8px;">
                <option value="1">Cada 1 hora</option>
                <option value="12">Cada 12 horas</option>
                <option value="24" selected>Cada 24 horas</option>
                <option value="48">Cada 48 horas (2 días)</option>
                <option value="168">Cada 168 horas (1 semana)</option>
              </select>
            </div>

            <div class="field" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; flex-direction: row;">
              <input type="checkbox" id="cycle-active" style="width: 20px; height: 20px; accent-color: var(--gold);" />
              <label for="cycle-active" style="color: var(--text); font-weight: 600;">Activar este ciclo</label>
            </div>

            <button id="btn-save-cycle" class="btn btn-gold btn-full">
              <span id="btn-cycle-text">💾 Guardar Configuración</span>
              <span id="btn-cycle-loading" class="loading-spinner" hidden></span>
            </button>

            <p id="cycle-success" class="success-msg" style="text-align: center; margin-top: 1rem; display: none;">
              ¡Configuración guardada exitosamente!
            </p>
          </section>
        </div>
      )
    }
  </main>
</Base>

<script>
  const form = document.getElementById('login-form');
  if (form) {
    const button = document.getElementById('login-button');
    form.addEventListener('submit', () => {
      // Deshabilitar el botón para evitar envíos múltiples y dar feedback al usuario.
      button.setAttribute('disabled', 'true');
      button.textContent = 'Ingresando...';
    });
  }

  // Si el usuario SÍ está logueado, importamos los scripts del panel
  if (document.getElementById('admin-view')) {
    import('../scripts/admin/index.js');
  }
</script>

<style>
  .login-box {
    max-width: 480px;
    margin: 4rem auto;
    padding: 2.5rem;
    text-align: center;
  }
  .error-msg {
    color: var(--danger);
    font-size: 0.9rem;
  }
  .success-msg {
    color: var(--success);
    font-size: 0.9rem;
  }
  .login-box .logo {
    justify-content: center;
    margin-bottom: 2rem;
  }
  .login-box .section-body {
    margin-bottom: 2rem;
  }
  .input-group.vertical {
    flex-direction: column;
    gap: 1rem;
  }
  .subtle-link {
    display: block;
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
  }
  .admin-card {
    padding: 2rem;
    margin-bottom: 2rem;
  }
  .card-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .client-name {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--gold);
  }
  .client-rut {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .cortes-display {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    background: rgba(0, 0, 0, 0.2);
    padding: 1rem;
    border-radius: var(--r-md);
    margin-bottom: 1.5rem;
  }
  .cortes-count {
    font-size: 2.5rem;
    font-family: var(--mono);
    font-weight: 700;
  }
</style>