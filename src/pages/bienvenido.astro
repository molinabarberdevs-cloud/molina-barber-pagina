---
import Base from '../layouts/Base.astro';
import BannerGeolocalizacion from '../components/bienvenido/BannerGeolocalizacion.astro';
import BannerPush from '../components/bienvenido/BannerPush.astro';
import BannerInstalacion from '../components/bienvenido/BannerInstalacion.astro';
import SeccionQr from '../components/bienvenido/SeccionQr.astro';
import TarjetaVip from '../components/bienvenido/TarjetaVip.astro';
import GuiaIos from '../components/bienvenido/GuiaIos.astro';

// Leer parámetros estáticos iniciales como fallback
const { searchParams } = Astro.url;
const nombreFallback = searchParams.get('nombre') || '';
const esNuevo = searchParams.get('nuevo') !== 'false';
// La variable usaWallet no se estaba utilizando, se puede eliminar si no tiene otro propósito.
// const usaWallet = searchParams.get('wallet') === 'true';
---

<Base
  title="Tu Tarjeta | Molina's"
  description="Revisa tu progreso en el Club Molina's."
  showDeviceFrame={true}
>
  <main class="page-welcome">
    <div class="wrap" style="padding-top: 4rem;">

      <!-- Icono de éxito festivo -->
      <div class="hero-icon-wrapper anim">
        <div class="hero-icon anim-pop d1">✨</div>
      </div>

      <!-- Mensaje principal -->
      <section class="hero-text anim d2">
        <h1 class="display" style="font-size: clamp(2rem, 8vw, 3.5rem); line-height: 1.1;">
          {esNuevo ? '¡Ya estás dentro,' : '¡Qué bueno verte,'} <br/>
          <span class="display-italic" id="user-name">{nombreFallback || 'Amigo'}</span>!
        </h1>

        <p class="hero-subtitle" id="user-subtitle">
          {esNuevo
            ? 'Tu primer corte ya está asegurado en nuestro sistema. ¡Empezaste con todo!'
            : 'Tu cuenta ya estaba registrada. Cargando tu progreso actual...'}
        </p>
      </section>




      <!-- Las acciones y componentes ahora están modularizados -->
      <section class="next-action anim d4">
        <BannerGeolocalizacion/>
        <BannerPush/>
        <BannerInstalacion/>
        <SeccionQr/>
        <TarjetaVip/>
      </section>

      <!-- Footer -->
      <footer class="footer-bottom anim d5">
        <button id="btn-logout" class="btn btn-ghost btn-full" style="margin-bottom: 2rem;">
          🚪 Salir / Cerrar Sesión
        </button>
      </footer>
    </div>

    <GuiaIos/>
  </main>
</Base>

<script>
  // Importamos el script principal que orquestará todo
  import '../scripts/bienvenido/index.js';
</script>

<style is:global>
  @keyframes bounce-in {
    0% { opacity: 0; transform: translate(-50%, 50px) scale(0.9); }
    100% { opacity: 1; transform: translate(-50%, 0) scale(1); }
  }
  @keyframes point-down {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 6px); }
  }

  .page-welcome {
    min-height: 100dvh;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  /* Hero & Icon */
  .hero-icon-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .hero-icon {
    font-size: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--gold-light), var(--gold-dark));
    border-radius: var(--r-full);
    box-shadow: 0 10px 30px var(--gold-glow), inset 0 2px 5px rgba(255,255,255,0.5);
    text-shadow: 0 2px 10px rgba(0,0,0,0.2);
  }

  .hero-text {
    text-align: center;
    margin-bottom: 3rem;
  }
  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-top: 1rem;
    max-width: 360px;
    margin-inline: auto;
    line-height: 1.6;
  }

  /* ═══ VIP Card Premium ═══ */
  .vip-card {
    padding: 0;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 215, 0, 0.15);
    background: linear-gradient(145deg, rgba(30, 28, 22, 0.7), rgba(20, 18, 14, 0.9));
    margin-bottom: 2rem;
  }

  .vip-shimmer {
    position: absolute;
    top: -50%; left: -50%;
    width: 200%; height: 200%;
    background: linear-gradient(
      to bottom right,
      rgba(255,215,0,0) 0%,
      rgba(255,215,0,0.03) 40%,
      rgba(255,215,0,0.12) 50%,
      rgba(255,215,0,0.03) 60%,
      rgba(255,215,0,0) 100%
    );
    transform: rotate(30deg) translateY(-100%);
    animation: vip-shine 6s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }
  @keyframes vip-shine {
    0% { transform: rotate(30deg) translateY(-100%); }
    30%, 100% { transform: rotate(30deg) translateY(100%); }
  }

  .card-glow {
    position: absolute;
    top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 200px; height: 200px;
    background: var(--gold);
    filter: blur(100px);
    opacity: 0.2;
    pointer-events: none;
    border-radius: 50%;
    z-index: 0;
  }

  .vip-card-inner {
    position: relative;
    z-index: 1;
    padding: 2rem;
  }

  .vip-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .vip-brand {
    display: block;
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  .vip-member-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--gold);
    background: var(--gold-subtle);
    padding: 0.2rem 0.6rem;
    border-radius: var(--r-full);
    margin-top: 0.4rem;
  }

  .vip-count {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--gold);
    text-shadow: 0 0 25px var(--gold-glow);
    line-height: 1;
  }

  /* Estampas VIP */
  .vip-stamps {
    display: flex;
    gap: 10px;
    margin-bottom: 2rem;
  }

  .vip-stamp {
    flex: 1;
    aspect-ratio: 1;
    max-width: 58px;
    border-radius: var(--r-md);
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 4px 10px rgba(0,0,0,0.4);
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
  }

  .vip-stamp-icon {
    font-size: 1.1rem;
    opacity: 0.25;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    filter: grayscale(1);
  }

  /* Estampa activa (llena) */
  .vip-stamp.filled {
    background: linear-gradient(135deg, var(--gold-light), var(--gold-dark));
    border: none;
    box-shadow: 0 4px 20px var(--gold-glow), inset 0 2px 4px rgba(255,255,255,0.4);
    transform: scale(1.05);
  }
  .vip-stamp.filled .vip-stamp-icon {
    opacity: 1;
    filter: grayscale(0) drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  /* Último (regalo) */
  .vip-stamp-gift {
    border: 1.5px dashed rgba(255,215,0,0.25);
    background: rgba(255,215,0,0.03);
  }
  .vip-stamp-gift .vip-stamp-icon {
    font-size: 1.3rem;
    opacity: 0.5;
    filter: none;
  }
  .vip-stamp-gift.filled {
    border-style: solid;
    border-color: var(--gold);
    animation: pop 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .vip-stamp-gift.filled .vip-stamp-icon {
    opacity: 1;
    animation: float 2s ease-in-out infinite;
  }

  /* Bottom */
  .vip-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .vip-progress-msg {
    font-size: 0.95rem;
    color: var(--text);
    text-align: center;
    line-height: 1.5;
  }

  .action-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .action-note {
    font-size: 0.8rem;
    color: var(--text-subtle);
    text-align: center;
    margin-top: 1rem;
    line-height: 1.4;
  }

  /* Notificación estilo Widget iOS/Modern App */
  .wp-widget {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--r-lg);
    padding: 1.25rem;
    margin-top: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    position: relative;
    z-index: 1;
    backdrop-filter: blur(10px);
  }

  .wp-widget-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .wp-icon {
    font-size: 1rem;
  }

  .wp-title {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text);
  }

  .wp-time {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--text-subtle);
  }

  .wp-widget-body {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .wp-widget-body strong {
    color: var(--text);
  }

  /* Footer */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    padding-bottom: 2rem;
    margin-top: 1rem;
  }

  /* ═══ QR Section ═══ */
  .qr-section {
    padding: 2rem;
    text-align: center;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255, 215, 0, 0.1);
  }

  .qr-header {
    margin-bottom: 2rem;
  }

  .qr-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--gold);
    background: var(--gold-subtle);
    padding: 0.3rem 0.8rem;
    border-radius: var(--r-full);
  }

  .qr-canvas-wrap {
    position: relative;
    display: inline-block;
    padding: 1rem;
    background: white;
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4), 0 0 40px var(--gold-glow);
    margin-bottom: 1.5rem;
  }

  .qr-canvas {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 220px;
    min-height: 220px;
  }

  .qr-glow {
    position: absolute;
    inset: -20px;
    border-radius: 30px;
    background: radial-gradient(circle, var(--gold-glow) 0%, transparent 70%);
    z-index: -1;
    animation: float 6s ease-in-out infinite;
  }

  .qr-rut-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .premium-card {
    padding: 2rem;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }
</style>
