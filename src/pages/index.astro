---
import Base from '../layouts/Base.astro';
---

<Base title="Molina's Premium Club">
  <main class="page">

    <!-- ══════════════════════════════════════════
         HERO — Efecto WOW, Dinámico y Vibrante
    ══════════════════════════════════════════ -->
    <section class="hero" aria-label="Bienvenida Molina's Barbería Premium">

      <!-- Imagen de fondo real (A color, sin filtro muerto) -->
      <div class="hero-bg">
        <img
          src="/photos/foto-equipo-limpia.png"
          alt="Interior de Molina's Barbería Premium"
          class="hero-img"
          loading="eager"
          fetchpriority="high"
        />
        <!-- Overlay oscuro hacia azul/morado muy sutil para dar riqueza -->
        <div class="hero-overlay" aria-hidden="true"></div>
      </div>

      <!-- Header / Logo arriba -->
      <header class="hero-header wrap anim">
        <div class="logo">
          <span class="logo-icon anim-pop d1">✂️</span>
          <div>
            <span class="logo-name">Molina's</span>
            <span class="logo-sub">Barbería Premium</span>
          </div>
        </div>
        <div class="location-chip glass-panel">
          <span class="chip-dot" aria-hidden="true"></span>
          San Antonio
        </div>
      </header>

      <!-- Contenido sobre la imagen -->
      <div class="hero-content wrap">

        <!-- Texto hero -->
        <div class="hero-text anim d2">
          <p class="eyebrow">Since 2020</p>
          <h1 class="hero-headline display">
            No es solo<br/>
            un corte.<br/>
            <em class="display-italic">Es presencia.</em>
          </h1>
          <p class="hero-desc">
            El ambiente exclusivo, la atención de primera
            y el estilo que te hace destacar — todo bajo un mismo techo.
          </p>
        </div>

        <!-- CTA -->
        <div class="hero-cta anim d3">
          <a href="#club" class="btn-hero" id="btn-ver-club">
            Descubrir el Club
            <svg viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true">
              <path d="M10 4v12M4 10l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <p class="hero-cta-sub">100% Gratis · Sin apps · Solo beneficios</p>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         EXPERIENCIA
    ══════════════════════════════════════════ -->
    <section class="experience wrap" aria-label="La experiencia Molina's">
      <div class="exp-grid">

        <!-- Video/Foto -->
        <div class="exp-photo-wrap anim floating">
          <video
            class="exp-photo"
            autoplay
            loop
            muted
            playsinline
            poster="/photos/foto-barbero.jpg"
          >
            <source src="/photos/video-experiencia.mp4" type="video/mp4" />
            <img
              src="/photos/foto-barbero.jpg"
              alt="Fachada de Molina's Barbería"
              class="exp-photo"
              loading="lazy"
            />
          </video>
          <div class="exp-photo-tag glass-panel">📍 Maestranza 1703</div>
        </div>

        <!-- Texto -->
        <div class="exp-text anim d1">
          <p class="section-eyebrow">La experiencia</p>
          <h2 class="section-title display">
            Aquí no vienes<br/>a cortarte el pelo.
          </h2>
          <p class="section-body">
            Vienes a elevar tu imagen. Cortes de autor, ambiente exclusivo,
            servicio personalizado y los detalles que hacen única a la barbería
            más top de San Antonio.
          </p>

          <ul class="exp-list" role="list">
            <li class="exp-list-item">
              <span class="exp-check" aria-hidden="true">✓</span>
              Cortes italianos y cambios de look
            </li>
            <li class="exp-list-item">
              <span class="exp-check" aria-hidden="true">✓</span>
              Manicura para hombres
            </li>
            <li class="exp-list-item">
              <span class="exp-check" aria-hidden="true">✓</span>
              Ambiente y música en vivo
            </li>
          </ul>

          <a
            href="https://instagram.com/molinasbarberia"
            class="exp-ig-link btn btn-ghost"
            target="_blank"
            rel="noopener noreferrer"
          >
            Ver trabajos en Instagram →
          </a>
        </div>

      </div>
    </section>

    <!-- ══════════════════════════════════════════
         SEPARADOR
    ══════════════════════════════════════════ -->
    <div class="ornament anim d2">
      <span style="color: var(--gold); font-size: 1.2rem;">✦</span>
    </div>

    <!-- ══════════════════════════════════════════
         CLUB
    ══════════════════════════════════════════ -->
    <section class="club wrap" id="club" aria-labelledby="club-title">

      <div class="club-header anim">
        <p class="section-eyebrow">Loyalty Program</p>
        <h2 class="section-title display" id="club-title">
          Club Molina's
        </h2>
        <p class="section-body">
          Porque si ya eliges Molina's una y otra vez, mereces que se note.
          Cada visita acumula — y la sexta te la regalamos.
        </p>
      </div>

      <!-- Tarjeta de lealtad Glassmorphism -->
      <div class="card-3d-wrap" id="card-3d-index">
        <div class="loyalty-card glass-panel" role="img" aria-label="Tarjeta del Club Molina's">
          
          <!-- Destello animado sobre la tarjeta -->
          <div class="card-glow"></div>

          <div class="card-body">
            <div class="card-top">
              <span class="card-brand">Molina's Club</span>
              <span class="card-since">Since 2020</span>
            </div>

            <div class="card-stamps" aria-label="Progreso de cortes: 1 de 5">
              <div class="stamp active anim-pop d3">
                <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14" aria-hidden="true">
                  <path d="M8 1L9.8 5.6L14.7 6.1L11.2 9.2L12.4 14L8 11.4L3.6 14L4.8 9.2L1.3 6.1L6.2 5.6Z"/>
                </svg>
              </div>
              <div class="stamp" aria-label="Pendiente"></div>
              <div class="stamp" aria-label="Pendiente"></div>
              <div class="stamp" aria-label="Pendiente"></div>
              <div class="stamp gift" aria-label="Premio">🎁</div>
            </div>

            <div class="card-bottom">
              <div class="card-count">
                <span class="card-num">1</span>
                <span class="card-denom font-mono"> / 5</span>
              </div>
              <span class="card-label">visitas para tu regalo</span>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA principal -->
      <div class="club-cta anim d2">
        <a href="/registro" class="btn btn-gold btn-full" id="btn-unirme-club">
          Quiero unirme al Club
        </a>
        <a href="/ingresar" class="btn btn-ghost btn-full" id="btn-login-club" style="margin-top: 0.5rem;">
          Ya soy miembro - Ver mi progreso
        </a>
      </div>

      <!-- Features -->
      <ul class="features glass-panel anim d3" role="list">
        <li class="feature">
          <div class="feature-icon">📱</div>
          <div>
            <strong>Google Wallet</strong> — Tu tarjeta siempre en tu teléfono, actualizada mágicamente.
          </div>
        </li>
        <li class="feature">
          <div class="feature-icon">💬</div>
          <div>
            <strong>WhatsApp</strong> — Notificaciones discretas con tu progreso.
          </div>
        </li>
        <li class="feature">
          <div class="feature-icon">🛡️</div>
          <div>
            <strong>100% Protegido</strong> — Cumplimos la ley de protección de datos.
          </div>
        </li>
      </ul>

    </section>

    <!-- Footer -->
    <footer class="site-footer wrap">
      <div class="footer-rule" aria-hidden="true"></div>
      <p class="footer-copy">
        © Molina's Barbería Premium · Maestranza 1703
      </p>
      <a href="https://instagram.com/molinasbarberia" class="footer-ig" target="_blank" rel="noopener noreferrer">
        @molinasbarberia
      </a>
    </footer>

    <!-- Script de UX -->
    <script>
      // Auto-redirección si ya hay una sesión de socio iniciada (PWA / Pantalla de inicio)
      const savedRut = localStorage.getItem('userRut');
      if (savedRut) {
        window.location.href = `/bienvenido?rut=${savedRut}&nuevo=false`;
      }

      // Videos suaves y cinematográficos
      const videos = document.querySelectorAll('video');
      videos.forEach(v => {
        v.playbackRate = 0.6; // Más lento = más elegante

        // Fade suave cuando el video reinicia el loop
        v.addEventListener('timeupdate', () => {
          const timeLeft = v.duration - v.currentTime;
          if (timeLeft < 1) {
            v.style.opacity = String(timeLeft); // Fade out último segundo
          } else if (v.currentTime < 0.5) {
            v.style.opacity = String(Math.min(v.currentTime * 2, 1)); // Fade in
          } else {
            v.style.opacity = '1';
          }
        });
      });

      // ═══ TARJETA 3D: Giro al aparecer + Float + Loop ═══
      function initCard3D(wrapperId) {
        const wrap = document.getElementById(wrapperId);
        if (!wrap) return;

        let interval = null;

        function doSpin() {
          wrap.classList.remove('is-floating');
          wrap.classList.add('is-spinning');

          // Cuando termina el giro (0.8s), pasar a flotar
          setTimeout(() => {
            wrap.classList.remove('is-spinning');
            wrap.classList.add('is-floating');
          }, 850);
        }

        // Detectar cuando la tarjeta entra en pantalla al hacer scroll
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Aparece girando
              doSpin();
              // Cada 5 segundos, girar de nuevo
              interval = setInterval(doSpin, 5000);
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });

        observer.observe(wrap);
      }

      document.addEventListener('DOMContentLoaded', () => {
        initCard3D('card-3d-index');

        // Scroll suave y cinematográfico al hacer click en "Descubrir el Club"
        const btnClub = document.getElementById('btn-ver-club');
        if (btnClub) {
          btnClub.addEventListener('click', (e) => {
            e.preventDefault();
            const target = document.getElementById('card-3d-index');
            if (!target) return;

            const start = window.scrollY;
            const targetRect = target.getBoundingClientRect();
            const end = start + targetRect.top - (window.innerHeight / 2) + (targetRect.height / 2);
            const duration = 4000; // 4 segundos, paseo lento
            const startTime = performance.now();

            function easeInOutCubic(t) {
              return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
            }

            function animateScroll(currentTime) {
              const elapsed = currentTime - startTime;
              const progress = Math.min(elapsed / duration, 1);
              const eased = easeInOutCubic(progress);

              window.scrollTo(0, start + (end - start) * eased);

              if (progress < 1) {
                requestAnimationFrame(animateScroll);
              }
            }

            requestAnimationFrame(animateScroll);
          });
        }
      });
    </script>
  </main>
</Base>

<style is:global>
  /* ── PAGE ── */
  .page {
    min-height: 100dvh;
    padding-bottom: 4rem;
  }

  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.65) saturate(1.1); /* Imagen vibrante */
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      hsla(240, 20%, 5%, 0.4) 0%, /* Tono azul/morado muy sutil para profundidad */
      var(--bg) 95%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Hero header (logo) */
  .hero-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2rem;
    position: relative;
    z-index: 2;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon {
    font-size: 1.5rem;
    filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));
  }

  .logo-name {
    display: block;
    font-family: var(--sans);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1;
  }

  .logo-sub {
    display: block;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 4px;
  }

  .location-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text);
    padding: 0.4rem 0.8rem;
    border-radius: var(--r-full);
  }

  .chip-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 8px var(--success);
    animation: glow-pulse 2s ease-in-out infinite;
  }
  @keyframes glow-pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  /* Hero text */
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    display: inline-block;
    background: rgba(0,0,0,0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    backdrop-filter: blur(4px);
  }

  .hero-headline {
    font-size: clamp(3rem, 13vw, 4.8rem);
    color: var(--text);
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 20px rgba(0,0,0,0.6);
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 380px;
    font-weight: 400;
  }

  /* Hero CTA */
  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1.125rem 1.5rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-full);
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    transition: all var(--ease-spring);
  }

  .btn-hero:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.3);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
  }
  .btn-hero:active {
    transform: scale(0.96);
  }

  .hero-cta-sub {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-subtle);
    letter-spacing: 0.02em;
  }

  /* ══════════════════════════════════════
     EXPERIENCE
  ══════════════════════════════════════ */
  .experience {
    padding-block: 4rem;
  }

  .exp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .exp-photo-wrap {
    position: relative;
    border-radius: var(--r-xl);
    overflow: hidden;
    aspect-ratio: 4/5;
    max-height: 500px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .exp-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 1.5s ease;
  }

  .exp-photo-wrap:hover .exp-photo { transform: scale(1.05); }

  .exp-photo-tag {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    padding: 0.5rem 1rem;
    border-radius: var(--r-full);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(2.2rem, 9vw, 3.2rem);
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .section-body {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .exp-list-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
  }

  .exp-check {
    color: var(--gold);
    font-weight: 900;
    background: var(--gold-subtle);
    width: 24px; height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .exp-ig-link {
    width: 100%;
  }

  /* ══════════════════════════════════════
     CLUB
  ══════════════════════════════════════ */
  .club {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-bottom: 4rem;
    scroll-margin-top: 2rem; /* Fix para el soft scroll de CSS */
  }

  /* Loyalty Card Glassmorphism */
  .loyalty-card {
    position: relative;
    padding: 2rem;
    overflow: hidden;
  }
  
  /* Destello diagonal animado */
  .card-glow {
    position: absolute;
    top: -50%; left: -50%;
    width: 200%; height: 200%;
    background: linear-gradient(
      to bottom right,
      rgba(255,255,255,0) 0%,
      rgba(255,255,255,0.05) 40%,
      rgba(255,255,255,0.2) 50%,
      rgba(255,255,255,0.05) 60%,
      rgba(255,255,255,0) 100%
    );
    transform: rotate(30deg) translateY(-100%);
    animation: shine 8s infinite;
    pointer-events: none;
  }
  @keyframes shine {
    0% { transform: rotate(30deg) translateY(-100%); }
    20%, 100% { transform: rotate(30deg) translateY(100%); }
  }

  .card-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-brand {
    font-family: var(--sans);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text);
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  .card-since {
    font-size: 0.75rem;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 0.1em;
    background: rgba(0,0,0,0.4);
    padding: 0.2rem 0.6rem;
    border-radius: var(--r-full);
  }

  .card-stamps {
    display: flex;
    gap: 0.5rem;
  }

  .stamp {
    flex: 1;
    aspect-ratio: 1;
    max-width: 55px;
    border-radius: var(--r-md);
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 4px 10px rgba(0,0,0,0.3);
  }

  .stamp.active {
    background: linear-gradient(135deg, var(--gold-light), var(--gold-dark));
    border: none;
    color: var(--black);
    box-shadow: 0 4px 15px var(--gold-glow), inset 0 2px 4px rgba(255,255,255,0.5);
  }

  .stamp.gift {
    border: 1.5px dashed rgba(255,255,255,0.2);
    background: transparent;
    font-size: 1.2rem;
    box-shadow: none;
  }

  .card-bottom {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .card-count {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .card-num {
    font-family: var(--mono);
    font-size: 3rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    text-shadow: 0 0 20px var(--gold-glow);
  }

  .card-denom {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.4);
    font-weight: 600;
  }

  .card-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  /* Features en un panel glass */
  .features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: var(--r-xl);
  }

  .feature {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .feature strong { 
    color: var(--text); 
    font-weight: 600; 
  }

  .feature-icon {
    font-size: 1.2rem;
    background: rgba(0,0,0,0.2);
    width: 32px; height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    flex-shrink: 0;
  }

  /* ══════════════════════════════════════
     FOOTER
  ══════════════════════════════════════ */
  .site-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

