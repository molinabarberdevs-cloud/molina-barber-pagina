---
import Base from '../layouts/Base.astro';
import SeccionHeroe from '../components/inicio/SeccionHeroe.astro';
import SeccionExperiencia from '../components/inicio/SeccionExperiencia.astro';
import SeccionClub from '../components/inicio/SeccionClub.astro';
import PieDePagina from '../components/inicio/PieDePagina.astro';
---

<Base title="Molina's Premium Club">
  <main class="page">

    <!-- ══════════════════════════════════════════
         HERO — Efecto WOW, Dinámico y Vibrante
    ══════════════════════════════════════════ -->
    <SeccionHeroe />

    <!-- ══════════════════════════════════════════
         EXPERIENCIA
    ══════════════════════════════════════════ -->
    <SeccionExperiencia />

    <!-- ══════════════════════════════════════════
         SEPARADOR
    ══════════════════════════════════════════ -->
    <div class="ornament wrap anim d2">
      <span style="color: var(--gold); font-size: 1.2rem;">✦</span>
    </div>

    <!-- ══════════════════════════════════════════
         CLUB
    ══════════════════════════════════════════ -->
    <SeccionClub />

    <!-- Footer -->
    <PieDePagina />

    <!-- Script de UX -->
    <script src="../scripts/inicio/index.js"></script>
  </main>
</Base>

<style is:global>
  /* ── PAGE ── */
  .page {
    min-height: 100dvh;
    padding-bottom: 4rem;
  }
  .ornament {
    text-align: center;
  }
</style>
