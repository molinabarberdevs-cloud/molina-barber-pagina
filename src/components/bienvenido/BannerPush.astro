---
// Este componente invita al usuario a activar las notificaciones push.
---
<div id="push-consent-banner" class="glass-panel anim" style="margin-bottom: 1.5rem; display: none; border: 1px solid rgba(255, 215, 0, 0.15); padding: 1.25rem;">
  <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; text-align: left;">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
      <span style="font-size: 1.7rem;">🔔</span>
      <div>
        <h3 id="push-title" style="font-size: 0.95rem; font-weight: 700; color: var(--text);">Activar Notificaciones</h3>
        <p id="push-desc" style="font-size: 0.82rem; color: var(--text-muted); margin-top: 0.2rem; line-height: 1.4;">Entérate al instante cuando sumes visitas y obtengas tu premio.</p>
      </div>
    </div>
    <button id="btn-request-push" class="btn btn-gold" style="padding: 0.5rem 1rem; font-size: 0.8rem; width: auto; flex-shrink: 0;">
      Activar
    </button>
  </div>
</div>